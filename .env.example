# Compose/runtime
TZ=Asia/Ho_Chi_Minh
NODE_ENV=production
PORT=8080
CLIENT_URL=http://localhost
CORS_ORIGIN=

# MySQL container runtime
MYSQL_ROOT_PASSWORD=replace_with_strong_root_password
MYSQL_DATABASE=badminton_booking

# Backend, worker, migrate, seed runtime
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=replace_with_db_password
DB_NAME=badminton_booking

# Seed runtime only
DEMO_PASSWORD=replace_with_demo_account_password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=@Admin123456
ADMIN_EMAIL=admin@example.com
ADMIN_FULL_NAME=Admin
ADMIN_PHONE=0901000001

# Backend and worker runtime
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Backend runtime secrets
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_ACCESS_EXPIRE=1h
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_EXPIRE=7d

# Backend runtime email
EMAIL_USER=replace_with_email@example.com
EMAIL_PASS=replace_with_email_app_password

# Backend runtime Cloudinary
CLOUD_NAME=replace_with_cloudinary_cloud_name
API_KEY=replace_with_cloudinary_api_key
API_SECRET=replace_with_cloudinary_api_secret

# Backend runtime VNPay sandbox
VNP_TMN_CODE=replace_with_vnp_tmn_code
VNP_HASH_SECRET=replace_with_vnp_hash_secret
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost/vnpay/result
VNP_IPN_URL=http://localhost/api/user/webhook/vnpay

# Backend runtime GHN development API
GHN_BASE_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_TOKEN_DEV=replace_with_ghn_dev_token

# Backend runtime OpenAI
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_API_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

# Frontend build-time only
VITE_BACKEND_URL=/api
VITE_SOCKET_URL=
