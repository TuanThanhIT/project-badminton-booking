{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for badminton court booking and management system using Node.js and Express",
  "keywords": [
    "badminton",
    "booking",
    "manager",
    "nodejs",
    "express"
  ],
  "license": "ISC",
  "author": "Nguyễn Tuấn Thành, Huỳnh Thái Toàn",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node src/server.js",
    "worker": "node src/workers/ghnWebhookWorker.js",
    "build": "babel src/server.js -d dist",
    "dev": "npm run build && nodemon src/server.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "seed": "sequelize-cli db:seed:all",
    "seed:check-operations": "node scripts/check-operational-seed.cjs",
    "seed:refresh-branch-descriptions": "node scripts/refresh-branch-seed-descriptions.cjs",
    "seed:refresh-product-media": "node scripts/refresh-product-seed-media.cjs",
    "seed:undo": "sequelize-cli db:seed:undo",
    "seed:undo:all": "sequelize-cli db:seed:undo:all"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@vitest/coverage-v8": "^4.1.8",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.5",
    "cloudinary": "^1.30.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.10.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.14.5",
    "nodemailer": "^7.0.6",
    "redis": "^5.12.1",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.5",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0",
    "vnpay": "^2.4.4"
  }
}
