      { "username": "demo_customer_001", "branchId": 1, "expect": "Gợi ý 19h + chi nhánh 1" },
      { "username": "demo_customer_006", "branchId": 2, "expect": "Gợi ý 6h sáng + chi nhánh 2" },
      { "username": "demo_customer_011", "branchId": 3, "expect": "Gợi ý 20h + chi nhánh 3" }
    ],
    "productPersona": [
      { "username": "demo_customer_001", "persona": "RACKET", "expect": "Gợi ý SP chưa mua (cước, balo…)" },
      { "username": "demo_customer_002", "persona": "COMBO", "expect": "Đã mua vợt+cước → gợi ý balo/giày" },
      { "username": "demo_customer_003", "persona": "BAG", "expect": "Hay mua balo → gợi ý khác balo" }
