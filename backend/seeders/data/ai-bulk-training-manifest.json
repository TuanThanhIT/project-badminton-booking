  "productCombos": {
    "boughtTogether": {
      "anchor": "Yonex Nanoflare Skill Vợt (productId ~10000)",
      "kem": ["Cước đan vợt Yonex BG65 (~918)", "Balo Yonex Pro Tour 30L (~914)"],
      "ordersPerBranch": 24
    },
    "shoeKit": {
      "items": ["Giày cầu lông Yonex (~911)", "Balo (~914)"],
      "ordersPerBranch": 12
    }
  },
  "verifySql": [
    "SELECT COUNT(*) FROM Bookings WHERE note LIKE '%AI-BULK-TRAIN%';",
    "SELECT COUNT(*) FROM OrderGroups WHERE note LIKE '%AI-BULK-TRAIN%' AND status='PAID';",
    "SELECT b.branchId, HOUR(bd.startTime) AS hour, COUNT(*) AS cnt FROM BookingDetails bd JOIN Bookings b ON b.id=bd.bookingId WHERE b.note LIKE '%AI-BULK-TRAIN%' AND bd.playDate >= DATE_SUB(CURDATE(), INTERVAL 30 DAY) GROUP BY b.branchId, hour ORDER BY b.branchId, hour;"
  ]
