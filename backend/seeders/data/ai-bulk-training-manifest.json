{
  "marker": "[DEMO-SEED-3M] AI-BULK-TRAIN",
  "seeder": "20260619100000-seed-ai-bulk-training-data.cjs",
  "run": "cd backend && npx sequelize-cli db:seed --seed 20260619100000-seed-ai-bulk-training-data.cjs",
  "undo": "cd backend && npx sequelize-cli db:seed:undo --seed 20260619100000-seed-ai-bulk-training-data.cjs",
