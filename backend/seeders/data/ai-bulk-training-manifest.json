    "habits": [
      { "branchId": 1, "pattern": "19h T2/T4/T6" },
      { "branchId": 2, "pattern": "6h T7/CN" },
      { "branchId": 3, "pattern": "20h T3/T5" },
      { "branchId": 4, "pattern": "17–19h T2/T6" },
      { "branchId": 5, "pattern": "18h CN/T4" }
    ],
    "occupancy": "Mỗi chi nhánh: nhiều booking 18–21h, ít 7–8h (28 ngày gần nhất)"
  },
  "testAccounts": {
    "password": "@Demo123456",
