APP_NAME=badminton-image-search-service
HOST=0.0.0.0
PORT=8010
TEXT_MODEL_NAME=sentence-transformers/clip-ViT-B-32-multilingual-v1
IMAGE_MODEL_NAME=sentence-transformers/clip-ViT-B-32
DEVICE=cpu
